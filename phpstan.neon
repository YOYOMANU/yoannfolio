includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon

parameters:
    ignoreErrors:
        - '#Template type TDeclaringModel on class Illuminate\\Database\\Eloquent\\Relations\\.* is not covariant#'
    paths:
        - app/
        - bootstrap/app.php
        - config/
        - database/
        - routes/

    level: 7
